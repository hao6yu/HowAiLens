# Local backend settings
HAOLENS_BACKEND_PORT=8787
HAOLENS_MAX_UPLOAD_BYTES=2097152
HAOLENS_OLED_LINE_CHARS=12
HAOLENS_OLED_MAX_LINES=3

# V0.6 AI vision settings
# Copy this file to .env and fill in the API key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_IMAGE_DETAIL=low
OPENAI_TIMEOUT_MS=30000

# Used when OPENAI_API_KEY is empty.
HAOLENS_AI_MOCK_TEXT=AI off
